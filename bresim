_ENEMY_DAMAGE_TABLE = {
    1:  ([(6, 1)],         "1d6"),
    2:  ([(4, 2)],         "2d4"),
    3:  ([(10, 1)],        "1d10"),
    4:  ([(12, 1)],        "1d12"),
    5:  ([(6, 1), (8, 1)], "1d6+1d8"),
    6:  ([(8, 2)],         "2d8"),
    7:  ([(6, 3)],         "3d6"),
    8:  ([(10, 2)],        "2d10"),
    9:  ([(10, 1),(12, 1)],"1d10+1d12"),
    10: ([(10, 3)],        "3d10"),
}

def roll_enemy_damage(hd):
    dice, label = _ENEMY_DAMAGE_TABLE.get(hd, ([(6,1)], "1d6"))
    total = sum(random.randint(1, s) for s, c in dice for _ in range(c))
    return total, label

def roll_enemy_hp(hd):
    """Each enemy HD is 1d8 HP."""
    return sum(random.randint(1, 8) for _ in range(hd))

