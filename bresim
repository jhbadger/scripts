BRE (Barbarians of the Ruined Earth) Combat Simulator
======================================================
Pits a randomly generated level-1 Barbarian against a random Bestiary creature.
Every die roll is explained so new players can learn the rules.

Run:  python3 bre_combat_sim.py
"""

import random

# ─── Dice helpers ─────────────────────────────────────────────────────────────

def roll(sides):
    return random.randint(1, sides)

def roll_adv(sides):
    """Roll 2d{sides} with Advantage: take the LOWER result."""
    r1, r2 = roll(sides), roll(sides)
    return min(r1, r2), r1, r2

def roll_disadv(sides):
    """Roll 2d{sides} with Disadvantage: take the HIGHER result."""
    r1, r2 = roll(sides), roll(sides)
    return max(r1, r2), r1, r2

def exploding_damage(sides, log):
    """
    Barbarian ATTACKER ability: if you roll the max value on a damage die,
    roll it again and add the result.  Keep going as long as you keep rolling max.
    """
    total, rolls = 0, []
    r = roll(sides)
    rolls.append(r)
    total += r
    while r == sides:
        log.append(f"    *** EXPLODING DAMAGE! Rolled max ({sides}) — rolling again!")
        r = roll(sides)
        rolls.append(r)
        total += r
    return total, rolls

